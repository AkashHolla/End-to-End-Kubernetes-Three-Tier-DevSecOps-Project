pipeline {
    agent any
    tools {
        jdk 'jdk'
        nodejs 'nodejs'
    }
    environment {
        JAVA_HOME = '/usr/lib/jvm/java-17-openjdk-amd64/bin/java'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"
        SCANNER_HOME = tool 'sonar-scanner'
        AWS_ACCOUNT_ID = credentials('ACCOUNT_ID')
        AWS_ECR_REPO_NAME = credentials('ECR_REPO1')
        AWS_DEFAULT_REGION = 'us-east-1'
        REPOSITORY_URI = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com/${AWS_ECR_REPO_NAME}"
    }
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }}
        stage('Checkout from GitHub') {
            steps {
                git branch:'main', credentialsId: 'GITHUB-APP', url: 'https://github.com/AkashHolla/End-to-End-Kubernetes-Three-Tier-DevSecOps-Project.git'
            }
        }
            stage('SonarQube Analysis'){
                steps {
                    withSonarQubeEnv('sonar-server') {
                         sh ''' 
                         export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
                         export PATH=$JAVA_HOME/bin:$PATH
                         
                         echo "JAVA_HOME=$JAVA_HOME"
                         which java
                         java -version
                         $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=frontend \
                        -Dsonar.projectKey=frontend '''
                    }
                }
            }
            stage('Quality Gate') {
                steps {
                    script {
                        waitForQualityGate abortPipeline: false, credentialsId: 'sonar-token'
                    }
                }
            }
            // stage('OwasP Dependency Check') {
            //     steps {
            //         dir('Application-Code/frontend') {
            //         dependencyCheck additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit', odcInstallation: 'DP-Check'
            //         dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            //         }
            //     }
            // }
            stage('trivy file scan') {
                steps {
                    dir('Application-Code/frontend') {
                        sh 'trivy fs . > trivyfs.txt'
                    }
                }
            }
            stage('Build Docker Image') {
                steps {
                    script{
                        dir('Application-Code/frontend') {
                            sh 'docker system prune -f'
                            sh 'docker container prune -f'
                            sh 'docker build -t ${AWS_ECR_REPO_NAME}:${BUILD_NUMBER} .'
                    }    }
                }
            }
            stage('Push to ECR') {
                steps {
                    script {
                       sh '''
                       set -x   # show commands
                       set -e   # fail on error
                        aws ecr get-login-password --region ${AWS_DEFAULT_REGION} | \
                        docker login --username AWS --password-stdin ${REPOSITORY_URI}
                
                        echo "Checking available images..."
                        docker images
                
                        docker tag ${AWS_ECR_REPO_NAME}:${BUILD_NUMBER} ${REPOSITORY_URI}:${BUILD_NUMBER}
                
                        docker push ${REPOSITORY_URI}:${BUILD_NUMBER}
                         '''
                    }
                }
            }
            stage('trivy image scan') {
                steps {
                    sh "trivy image ${REPOSITORY_URI}:${BUILD_NUMBER} > trivyimage.txt"
                }
            }
            stage('checkout code for kubernetes') {
                steps {
                    git branch: 'main', credentialsId: 'GITHUB-APP', url: 'https://github.com/AkashHolla/End-to-End-Kubernetes-Three-Tier-DevSecOps-Project.git'
                }
            }
            stage('DEBUG BEFORE UPDATE') {
                steps {
                    echo "Reached before update stage"
                }
            }
            stage('Update Deployment File') {
    environment {
        GIT_REPO_NAME = 'End-to-End-Kubernetes-Three-Tier-DevSecOps-Project'
        GIT_USER_NAME = 'AkashHolla'
    }
    steps {
        dir('Kubernetes-Manifests-file/Frontend') {
            withCredentials([usernamePassword(
                credentialsId: 'GITHUB-APP',
                usernameVariable: 'GIT_USER',
                passwordVariable: 'GITHUB_TOKEN'
            )]) {

                echo "INSIDE CREDENTIALS BLOCK ✅"

                sh '''
                set -x

                echo "Current directory:"
                pwd
                ls -l

                echo "Before update:"
                cat deployment.yaml

                sed -i "s|image: .*|image: ${REPOSITORY_URI}:${BUILD_NUMBER}|g" deployment.yaml

                echo "After update:"
                cat deployment.yaml

                git config user.email "akashholla2025@gmail.com"
                git config user.name "AkashHolla"

                git add deployment.yaml
                git commit -m "Update deployment Image to version ${BUILD_NUMBER}" || echo "No changes"

                git push https://${GIT_USER}:${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                '''
            }
        }
    }
}
}
}